generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             Int             @id @default(autoincrement())
  slug           String          @unique @default("")
  badge          String
  badgeType      String
  brand          String
  name           String
  emoji          String          @default("🌿")
  rating         Float
  reviewCount    Int
  price          String
  originalPrice  String
  savings        String
  tags           String
  categories     String
  description    String          @default("")
  image          String          @default("")
  pros           String          @default("")
  cons           String          @default("")
  review         String          @default("")
  createdAt      DateTime        @default(now())
  affiliateLinks AffiliateLink[]
}

model AffiliateLink {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  retailer  String
  url       String
  price     String   @default("")
  createdAt DateTime @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  emoji String
  price String
  slug  String @unique
}

model Review {
  id       Int    @id @default(autoincrement())
  text     String
  name     String
  location String
  initial  String
}

model Guide {
  id       Int    @id @default(autoincrement())
  emoji    String
  tag      String
  title    String
  readTime String
  updated  String
}

model Brand {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
